{
  "name": "@DuyMaiBui/mk-cli",
  "version": "1.0.0",
  "description": "CLI tool for managing OpenCode skills with mk-* modular helpers",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "mk": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest --run",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "opencode",
    "skills",
    "cli",
    "mk"
  ],
  "author": "duymaib",
  "license": "MIT",
  "dependencies": {
    "commander": "^12.0.0",
    "js-yaml": "^4.1.0",
    "chalk": "^5.3.0",
    "semver": "^7.6.0",
    "simple-git": "^3.24.0",
    "inquirer": "^9.2.0",
    "tar": "^7.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "tsx": "^4.7.0",
    "vitest": "^1.6.0",
    "@types/node": "^20.0.0",
    "@types/js-yaml": "^4.0.0",
    "@types/semver": "^7.5.0",
    "@types/inquirer": "^9.0.0"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "package.json"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
